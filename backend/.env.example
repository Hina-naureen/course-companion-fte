# ── App ───────────────────────────────────────────────────────────────────────
APP_NAME="Course Companion FTE"
DEBUG=true

# ── Database ──────────────────────────────────────────────────────────────────
# Local dev (SQLite):
DATABASE_URL=sqlite+aiosqlite:///./course_companion.db
# Production (PostgreSQL — recommended):
# DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/course_companion

# ── JWT ───────────────────────────────────────────────────────────────────────
# REQUIRED: generate a strong secret (e.g. `openssl rand -hex 32`)
JWT_SECRET_KEY=change-me-with-openssl-rand-hex-32
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# ── Phase 2: Claude Skills (optional) ────────────────────────────────────────
# Leave empty to run Phase 1 only (Zero-Backend-LLM).
# Set to mount /api/v1/skills/* endpoints.
ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-sonnet-4-6

# ── AI Tutor providers (optional, fallback chain) ─────────────────────────────
# Set at least one to enable /api/v1/ai/tutor and /api/v1/ai/generate-course.
# Leave all empty to run Phase 1 only.

# Primary: Google Gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# Fallback 1: OpenRouter (free models available)
OPENROUTER_API_KEY=
OPENROUTER_MODEL=meta-llama/llama-3.1-8b-instruct:free

# Fallback 2: OpenAI (also used for TTS)
OPENAI_API_KEY=

# ── Freemium limits ───────────────────────────────────────────────────────────
FREE_CHAPTER_LIMIT=3
FREE_SEARCH_DAILY_LIMIT=10
FREE_QUIZ_ATTEMPTS_DAILY=3
FREE_AI_EXPLAINS_DAILY=5

# ── CORS ──────────────────────────────────────────────────────────────────────
CORS_ORIGINS=["http://localhost:3000","https://chat.openai.com"]

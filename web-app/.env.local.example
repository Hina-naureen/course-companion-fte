# ── Backend API URL (optional override) ───────────────────────────────────────
# Leave unset to use the Next.js rewrite proxy (/api/v1 → BACKEND_URL).
# Set this only if you want the browser to call the backend directly
# (bypasses proxy; backend CORS must allow your origin).
#
# Local development:
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1
#
# Production direct — uncomment and replace with your deployed backend URL:
# NEXT_PUBLIC_API_URL=https://course-companion-backend.onrender.com/api/v1

# ── Backend proxy URL (server-side, used by next.config.ts rewrite) ───────────
# This is the base URL of the backend WITHOUT /api/v1.
# Set this in Vercel dashboard as BACKEND_URL (no NEXT_PUBLIC_ prefix).
#
# Local development:
BACKEND_URL=http://localhost:8000
#
# Production — set in Vercel dashboard:
# BACKEND_URL=https://course-companion-backend.onrender.com
